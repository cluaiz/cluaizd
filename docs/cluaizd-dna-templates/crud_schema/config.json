{
  "hook": "on_write",
  "engine": "rhai",
  "template": "crud_schema.rhai",
  "engine_settings_override": {
    "payload_format": "json",
    "concurrency_mode": "dashmap"
  },
  "parameters": {
    "required_fields": [
      {"name": "email", "type": "string"},
      {"name": "age", "type": "integer"}
    ]
  }
}
