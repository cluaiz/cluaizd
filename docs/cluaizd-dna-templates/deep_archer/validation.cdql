-- ==============================================================================
-- 🛡️ Deep Archer Validation Matrix (CDQL Edition)
-- ==============================================================================
-- For developers who want to stick purely to the Cluaiz Data Query Language.
-- ------------------------------------------------------------------------------

-- Use the BEFORE INSERT hook natively in CDQL
CREATE TRIGGER deep_archer_firewall
BEFORE INSERT ON workspace.neurons
EXECUTE PIPELINE (
    -- 1. Novelty Check
    LET is_spam = (
        FIND * 
        -> SIMILAR_TO(vector: NEW.vector_data, metric: 'cosine') 
        -> WHERE score > 0.98 
        -> LIMIT 1
    );
    
    -- 2. Alignment Check
    LET is_aligned = (
        NEW.raw_payload NOT CONTAINS ANY (CONFIG.forbidden_keywords)
    );

    -- 3. Evaluation
    IF is_spam {
        ABORT TRANSACTION "Deep Archer: Novelty Check failed (AI Spam detected)";
    }
    
    IF NOT is_aligned {
        ABORT TRANSACTION "Deep Archer: Alignment Check failed (Forbidden keywords detected)";
    }

    -- 4. Grounding Check (External fetch via CDQL stream pipe)
    IF CONFIG.enable_external_grounding {
        LET grounding_res = FETCH POST CONFIG.grounding_api_url WITH NEW.raw_payload;
        IF grounding_res.is_hallucination {
            ABORT TRANSACTION "Deep Archer: Grounding Check failed (Hallucination detected)";
        }
    }

    PROCEED;
);
