{
  "hook": "on_write",
  "engine": "auto_wasm",
  "template": "validation.auto_wasm.rs",
  "engine_settings_override": {
    "payload_format": "flatbuffers",
    "concurrency_mode": "dashmap"
  },
  "parameters": {
    "enable_external_grounding": true,
    "grounding_api_url": "http://localhost:8080/v1/grounding-check",
    "forbidden_keywords": [
      "password",
      "ssn",
      "credit_card",
      "ignore all previous instructions",
      "system prompt"
    ]
  }
}
